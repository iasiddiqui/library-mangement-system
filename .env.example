# MongoDB Connection String
# Replace with your actual MongoDB connection string
# For local MongoDB: mongodb://localhost:27017/library_management
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/library_management
MONGODB_URI=mongodb://localhost:27017/library_management

# Server Port
PORT=3000

# JWT Secret Key (Change this to a random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Node Environment
NODE_ENV=development
